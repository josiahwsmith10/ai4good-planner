{
  "name": "ai4good-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Unofficial time-grid / conflict-view planner for the AI for Good Global Summit (Geneva). Not affiliated with ITU.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "scrape": "tsx scripts/scrape.ts --year 2026 --out public/data/2026.json",
    "scrape:dry": "tsx scripts/scrape.ts --year 2026 --dry-run",
    "diff": "tsx scripts/diff.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.1.1",
    "@fontsource/ibm-plex-sans": "^5.1.1",
    "@fontsource/ibm-plex-sans-condensed": "^5.1.1",
    "lit-html": "^3.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "node-html-parser": "^7.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
